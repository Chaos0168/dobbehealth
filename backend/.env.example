# ─── All environment variables go here ───────────────────────────────────────
# Copy this file to .env and fill in your real values
# NEVER commit .env to git

# Database
DATABASE_URL=postgresql+asyncpg://admin:admin123@localhost:5432/dobbeai

# JWT Auth
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440   # 24 hours

# LLM — get free key from console.groq.com
GROQ_API_KEY=gsk_...

# MCP Server URL (runs on port 8001)
MCP_SERVER_URL=http://localhost:8001/sse

# Google Calendar — from Google Cloud Console
GOOGLE_CREDENTIALS_PATH=./services/google_credentials.json
GOOGLE_TOKEN_PATH=./services/google_token.json

# Resend — from resend.com (3000 free emails/month)
RESEND_API_KEY=re_...
FROM_EMAIL=appointments@dobbeai.com

# Slack — from api.slack.com
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=#doctor-notifications
